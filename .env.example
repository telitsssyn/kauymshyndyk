# Строка подключения PostgreSQL
# Локально: npm run dev:db поднимает базу на 5433
# Прод (Neon): возьмите Pooled connection string в консоли neon.tech
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/kauymshyndyk

# Секрет Payload (любая длинная случайная строка, на проде — своя!)
PAYLOAD_SECRET=change-me

# Публичный адрес сайта (на проде — https://ваш-домен)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Хранилище изображений Vercel Blob (только на проде; локально не нужно)
# BLOB_READ_WRITE_TOKEN=

# Данные администратора для сида (npm run seed)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=admin12345
